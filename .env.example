VITE_GAS_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# api/publish.js only — server-side, never exposed to the browser. The
# BGrowth Publishing Engine endpoint lives in bgrowth-portal; this is how
# Studio's serverless proxy reaches it without the secret ever touching
# client code. Do NOT prefix these with VITE_.
PORTAL_PUBLISHING_ENGINE_URL=https://your-portal-deployment.vercel.app/api/publishing-engine/publish
PORTAL_PUBLISHING_ENGINE_SECRET=a-long-random-shared-secret
